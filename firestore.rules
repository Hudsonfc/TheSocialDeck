rules_version = '2';
// Firestore Security Rules for The Social Deck
// Deploy: Firebase Console → Firestore → Rules, paste this and Publish.
// Or from CLI: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: document ID = Firebase Auth UID
    match /profiles/{userId} {
      // Any signed-in user can read profiles (needed for username check + friends)
      allow read: if request.auth != null;
      // Only the owner can create/update/delete their own profile
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
