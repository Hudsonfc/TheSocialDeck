rules_version = '2';
// Firestore Security Rules for The Social Deck
//
// IMPORTANT — "Create room" will fail with "Missing or insufficient permissions"
// until these rules are deployed to your Firebase project.
//
// Deploy manually:
//   1. Open https://console.firebase.google.com → your project → Firestore Database → Rules
//   2. Replace the rules there with the entire contents of this file (or add the rooms/roomInvites blocks if you already have rules)
//   3. Click "Publish"
//
// Or from terminal (if you use Firebase CLI): firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: document ID = Firebase Auth UID
    match /profiles/{userId} {
      // Any authenticated user can read profiles (needed for search/friends/request UI)
      allow read: if request.auth != null;
      // Only the owner can create/update/delete their own profile
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests
    match /friendRequests/{requestId} {
      // Read if I am either side of the request
      allow read: if request.auth != null &&
        (
          resource.data.fromUserId == request.auth.uid ||
          resource.data.toUserId == request.auth.uid
        );

      // Create only if the sender is me
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid;

      // Update/delete if I am either side of the request
      allow update, delete: if request.auth != null &&
        (
          resource.data.fromUserId == request.auth.uid ||
          resource.data.toUserId == request.auth.uid
        );
    }

    // Online rooms: document ID = room code
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }

    // Room invites (for inviting friends to rooms)
    match /roomInvites/{inviteId} {
      allow read, write: if request.auth != null;
    }
  }
}
