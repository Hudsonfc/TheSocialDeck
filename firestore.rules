rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // NOTE: Firestore rules cannot enforce field-level read access inside a single document.
    // With the current schema, profile reads stay authenticated-only to preserve search/friend flows.
    function validProfileWriteShape() {
      return request.resource.data.keys().hasOnly([
        "userId",
        "email",
        "gameCenterPlayerID",
        "username",
        "usernameLower",
        "avatarType",
        "avatarColor",
        "createdAt",
        "updatedAt",
        "lastUsernameChanged",
        "joinDate",
        "gamesPlayed",
        "gamesWon",
        "totalCardsSeen",
        "totalCardsFlipped",
        "favoriteGame",
        "cardsFlipped",
        "onlineGamesPlayed",
        "onlineGamesWon",
        "favoritedGames",
        "isOnline",
        "isPlus",
        "lastActiveAt",
        "lastSeen",
        "fcmToken"
      ]);
    }

    // Safe access — older room docs or bad data should not crash rule evaluation.
    function roomPlayersList(roomData) {
      let p = roomData.get('players', []);
      return p is list ? p : [];
    }

    function roomPlayersSize(roomData) {
      return roomPlayersList(roomData).size();
    }

    function roomPlayerIds(roomData) {
      return roomPlayersList(roomData).map(player, player.id);
    }

    function isExistingRoomPlayer() {
      return signedIn() && roomPlayerIds(resource.data).hasAny([request.auth.uid]);
    }

    // Joining a room updates only `players` by appending the current user — they are not
    // in resource.data yet, so isExistingRoomPlayer() alone would block legitimate joins.
    // Same write path is used after accepting a room invite (client then calls joinRoom).
    // We require: only `players` changed, exactly one new entry, and that entry is this user.
    function isJoiningByAppendingSelf() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['players'])
        && roomPlayersSize(request.resource.data) == roomPlayersSize(resource.data) + 1
        && roomPlayerIds(request.resource.data).hasAny([request.auth.uid])
        && !roomPlayerIds(resource.data).hasAny([request.auth.uid]);
    }

    function isRoomHost() {
      return signedIn() && resource.data.hostId == request.auth.uid;
    }

    // User profiles: document ID = Firebase Auth UID
    match /profiles/{userId} {
      // Authenticated read is required for search + friend request UI.
      allow read: if signedIn();

      // Only the owner can create/update, and only with expected profile keys.
      allow create, update: if isMe(userId) && validProfileWriteShape();
      allow delete: if isMe(userId);
    }

    // Friend requests
    match /friendRequests/{requestId} {
      // Read if I am either side of the request
      allow read: if signedIn() &&
        (
          resource.data.fromUserId == request.auth.uid ||
          resource.data.toUserId == request.auth.uid
        );

      // Create only if the sender is me
      allow create: if signedIn() &&
        request.resource.data.fromUserId == request.auth.uid;

      // Update/delete if I am either side of the request
      allow update, delete: if signedIn() &&
        (
          resource.data.fromUserId == request.auth.uid ||
          resource.data.toUserId == request.auth.uid
        );
    }

    // Online rooms: document ID = room code
    match /rooms/{roomId} {
      // Needed for join-via-code and lobby/game reads.
      allow read: if signedIn();

      // Any signed-in user can create a room.
      allow create: if signedIn();

      // Existing players can update (ready state, game fields, kick, etc.).
      // Authenticated users who are NOT yet in the room may update only when appending
      // themselves to `players` exactly once (join-by-code / after invite accept).
      allow update: if isExistingRoomPlayer() || isJoiningByAppendingSelf();

      // Only host can delete room.
      allow delete: if isRoomHost();
    }

    // Room invites (for inviting friends to rooms)
    match /roomInvites/{inviteId} {
      allow read, write: if signedIn();
    }

    // Default deny for any collections not explicitly covered above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
